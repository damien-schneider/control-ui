    },
    {
      "path": "src/registry/sources/control-ui/code-block-editor.tsx",
      "target": "@components/control-ui/code-block-editor.tsx",
      "type": "registry:component"
    }
  ],
  "meta": {
    "sourceManifestPath": "registry/control-ui/code-block-editor.json"
  }
}
