  "title": "CodeBlockEditor",
  "description": "Editable code surface with Shiki highlighting and token-based light/dark themes.",
  "dependencies": [
    "lucide-react@^1.24.0"
  ],
  "registryDependencies": [
    "button",
    "code",
    "core",
    "scroll-area",
