{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "chat-input",
  "type": "registry:component",
  "title": "ChatInput",
  "description": "Prompt composer with controlled text, submit state, and trigger-menu support.",
  "docs": "Add these imports once to app/globals.css: @import \"../components/control-ui/styles/chat-input-editor.css\";",
  "dependencies": [
    "prosemirror-commands@^1.7.1",
    "prosemirror-history@^1.5.0",
    "prosemirror-keymap@^1.2.3",
    "prosemirror-model@^1.25.11",
    "prosemirror-state@^1.4.4",
    "prosemirror-view@^1.42.1"
  ],
  "registryDependencies": [
    "button",
    "core",
    "scroll-area",
    "trigger-menu"
  ],
  "files": [
    {
      "path": "src/registry/hooks/use-chat-input.ts",
      "target": "@components/control-ui/hooks/use-chat-input.ts",
      "type": "registry:hook"
    },
    {
      "path": "src/registry/sources/control-ui/chat-input-editor.css",
      "target": "@components/control-ui/styles/chat-input-editor.css",
      "type": "registry:file"
    },
    {
      "path": "src/registry/sources/control-ui/chat-input-editor.tsx",
      "target": "@components/control-ui/chat-input-editor.tsx",
      "type": "registry:component"
    },
    {
      "path": "src/registry/sources/control-ui/chat-input-editor/extensions/mention.tsx",
      "target": "@components/control-ui/chat-input-editor/extensions/mention.tsx",
      "type": "registry:component"
    },
    {
      "path": "src/registry/sources/control-ui/chat-input-editor/ghost.ts",
      "target": "@components/control-ui/chat-input-editor/ghost.ts",
      "type": "registry:component"
    },
    {
      "path": "src/registry/sources/control-ui/chat-input-editor/schema.ts",
      "target": "@components/control-ui/chat-input-editor/schema.ts",
      "type": "registry:component"
    },
    {
      "path": "src/registry/sources/control-ui/chat-input-editor/serialize.ts",
      "target": "@components/control-ui/chat-input-editor/serialize.ts",
      "type": "registry:component"
    },
    {
      "path": "src/registry/sources/control-ui/chat-input-editor/types.ts",
      "target": "@components/control-ui/chat-input-editor/types.ts",
      "type": "registry:component"
    },
    {
      "path": "src/registry/sources/control-ui/chat-input.tsx",
      "target": "@components/control-ui/chat-input.tsx",
      "type": "registry:component"
    }
  ],
  "meta": {
    "sourceManifestPath": "registry/control-ui/chat-input.json"
  }
}
