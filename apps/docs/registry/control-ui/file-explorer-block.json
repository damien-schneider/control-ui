    {
      "path": "src/registry/blocks/control-ui/file-explorer.tsx",
      "target": "@components/control-ui/blocks/file-explorer.tsx",
      "type": "registry:block"
    }
  ],
  "meta": {
    "sourceManifestPath": "registry/control-ui/file-explorer-block.json"
