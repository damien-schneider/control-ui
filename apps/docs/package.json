  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:sync": "node scripts/sync-installed-fixture.mjs --watch",
    "build": "bun run sync && next build --webpack",
    "sync:skins": "bun scripts/gen-skin-theme.ts",
    "sync:contracts": "bun scripts/gen-skin-contract.ts",
    "sync:manifests": "bun scripts/gen-registry-manifests.ts",
    "sync:fixture": "node scripts/sync-installed-fixture.mjs",
    "sync:registry": "bun scripts/build-public-registry.ts",
    "sync:index": "bun scripts/gen-registry-index.ts",
    "sync": "bun run sync:skins && bun run sync:contracts && bun run sync:manifests && bun run sync:fixture && bun run sync:registry && bun run docs:agents && bun run sync:index",
    "docs:agents": "bun scripts/gen-agent-docs.ts",
    "validate:theme-contract": "bun test src/registry/skin-packs/theme-contract-coverage.test.ts src/registry/sources/control-ui/code-theme.test.ts",
    "skin:validate": "bun scripts/validate-skins.ts",
    "theme:a11y": "bun scripts/check-theme-accessibility.ts",
    "validate": "bun run validate:theme-contract && bun scripts/gen-skin-theme.ts --check && bun scripts/gen-skin-contract.ts --check && bun run skin:validate && bun scripts/gen-registry-manifests.ts --check && bun scripts/validate-docs-catalog.ts && node scripts/sync-installed-fixture.mjs --check && bun scripts/build-public-registry.ts --check && bun scripts/gen-registry-index.ts --check && bun scripts/gen-agent-docs.ts --check && bun scripts/validate-seo.ts && bun scripts/validate-registry.ts",
    "typecheck": "node scripts/ensure-next-types.mjs && tsc --noEmit",
    "lint": "biome lint .",
    "test": "bun test",
    "test:browser": "playwright test",
    "test:install": "bun run sync && node scripts/test-registry-install.mjs"
  },
