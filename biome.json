{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.next",
      "!**/.turbo",
      "!**/.vercel",
      "!**/coverage",
      "!**/dist",
      "!**/node_modules",
      "!**/package-lock.json",
      "!**/playwright-report",
      "!**/test-results",
      "!apps/docs/public/r/**/*.json",
      "!apps/docs/registry.json",
      "!apps/docs/registry/**/*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 140
  },
  "linter": {
    "enabled": true,
    "domains": {
      "test": "recommended",
      "turborepo": "recommended"
    },
    "rules": {
      "preset": "recommended",
      "complexity": {
        "noExcessiveCognitiveComplexity": "error",
        "noExcessiveNestedTestSuites": "error",
        "noImplicitCoercions": "error",
        "noRedundantDefaultExport": "error",
        "noUselessCatchBinding": "error",
        "noUselessReturn": "error",
        "noUselessStringConcat": "error",
        "useArrayFind": "error"
      },
      "correctness": {
        "noNestedComponentDefinitions": "error",
        "noNextAsyncClientComponent": "error",
        "noPrivateImports": "error",
        "noReactPropAssignments": "error",
        "noUndeclaredDependencies": "error",
        "noUnusedInstantiation": "error"
      },
      "performance": {
        "noBarrelFile": "error",
        "noImgElement": "off",
        "noNamespaceImport": "error",
        "noReExportAll": "error",
        "noSyncScripts": "error"
      },
      "style": {
        "noCommonJs": "error",
        "noDoneCallback": "error",
        "noEnum": "error",
        "noExportedImports": "error",
        "noHexColors": "error",
        "noMultiAssign": "error",
        "noNamespace": "error",
        "noNestedTernary": "error",
        "noParameterAssign": "error",
        "noUnusedTemplateLiteral": "error",
        "noUselessElse": "error",
        "noValueAtRule": "error",
        "noYodaExpression": "error",
        "useAsConstAssertion": "error",
        "useCollapsedElseIf": "error",
        "useCollapsedIf": "error",
        "useConsistentArrayType": "error",
        "useConsistentBuiltinInstantiation": "error",
        "useConsistentCurlyBraces": "error",
        "useDefaultParameterLast": "error",
        "useErrorCause": "error",
        "useExplicitLengthCheck": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case"]
          }
        },
        "useNodeAssertStrict": "error",
        "useNumberNamespace": "error",
        "useObjectSpread": "error",
        "useReactFunctionComponents": "error",
        "useSelfClosingElements": "error",
        "useSymbolDescription": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
        "useTrimStartEnd": "error"
      },
      "suspicious": {
        "noAlert": "error",
        "noConstantBinaryExpressions": "error",
        "noDeprecatedImports": "error",
        "noDuplicatedSpreadProps": "error",
        "noFocusedTests": "error",
        "noImportCycles": "error",
        "noMisplacedAssertion": "error",
        "noNestedPromises": "error",
        "noParametersOnlyUsedInRecursion": "error",
        "noReturnAssign": "error",
        "noShadow": "error",
        "noSkippedTests": "error",
        "noUnassignedVariables": "error",
        "noUndeclaredEnvVars": "error",
        "noUnknownAttribute": "error",
        "noUnusedExpressions": "error",
        "noVar": "error",
        "useErrorMessage": "error",
        "useNumberToFixedDigitsArgument": "error"
      }
    }
  },
  "css": {
    "formatter": {
      "enabled": false
    },
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["packages/skills/src/index.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/docs/src/registry/**/*.ts",
        "apps/docs/src/registry/**/*.tsx",
        "apps/docs/components/control-ui/**/*.ts",
        "apps/docs/components/control-ui/**/*.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "error"
          }
        }
      }
    },
    {
      "includes": [
        "apps/docs/src/registry/blocks/control-ui/**/*.tsx",
        "apps/docs/src/registry/sources/control-ui/**/*.tsx",
        "apps/docs/components/control-ui/**/*.tsx",
        "!apps/docs/src/registry/**/*.test.tsx"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "useUniqueElementIds": "error"
          }
        }
      }
    },
    {
      "includes": ["apps/docs/src/registry/sources/control-ui/**/*.tsx", "apps/docs/components/control-ui/**/*.tsx"],
      "plugins": [
        {
          "path": "./lint/no-react-dom-query.grit"
        }
      ]
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "noDuplicateClasses": "on",
        "organizeImports": "on"
      }
    }
  }
}
